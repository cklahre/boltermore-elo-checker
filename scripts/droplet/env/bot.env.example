# Copy to /opt/eloevent/env/bot.env (600) if you bootstrap before CI. Do NOT commit secrets.
# GitHub Actions deploy overwrites this file from repo secrets DISCORD_BOT_TOKEN and DISCORD_GUILD_ID.
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_guild_snowflake
# Optional: JWT from a logged-in bestcoastpairings.com session so /elo-factions can fetch detachments (GET /v1/armylists per list).
# BCP_BEARER_TOKEN=
